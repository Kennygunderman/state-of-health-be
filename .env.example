# Postgres connection string
DATABASE_URL=postgresql://user:password@localhost:5432/state_of_health

# USDA FoodData Central
USDA_API_KEY=

# OpenRouter (AI endpoints)
OPENROUTER_API_KEY=

# Base64 of the Firebase service account JSON. Optional locally — dev falls
# back to ./serviceAccountKey.json. Required in deployed environments:
#   base64 -i serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT=
