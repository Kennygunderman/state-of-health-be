generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model daily_exercises {
  id             String          @id(map: "daily_exercise_pkey") @db.Uuid
  workout_day_id String          @db.Uuid
  exercise_id    String          @db.Uuid
  order          Int?            @default(0)
  user_exercises user_exercises  @relation(fields: [exercise_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "daily_exercise_exercise_id_fkey")
  workout_days   workout_days    @relation(fields: [workout_day_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "daily_exercise_workout_day_id_fkey")
  exercise_sets  exercise_sets[]

  @@index([exercise_id], map: "idx_daily_exercises_exercise_id")
}

model exercise_sets {
  id                String          @id(map: "exercise_set_pkey") @db.Uuid
  daily_exercise_id String          @db.Uuid
  reps              Int?
  weight            Float?
  added_weight      Float?
  duration_seconds  Int?
  distance_meters   Float?
  rpe               Float?
  is_warmup         Boolean?        @default(false)
  completed         Boolean?        @default(false)
  set_number        Int?
  completed_at      DateTime?       @db.Date
  daily_exercises   daily_exercises @relation(fields: [daily_exercise_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "exercise_set_daily_exercise_id_fkey")
}

model user_exercises {
  id                 String             @id(map: "exercise_pkey") @db.Uuid
  name               String
  exercise_type      String
  exercise_body_part String
  logging_type       String             @default("WEIGHT_REPS")
  user_id            String?
  deleted_at         DateTime?          @db.Timestamptz(6)
  daily_exercises    daily_exercises[]
  personal_records   personal_records[]
  users              users?             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_exercise_user_id_fkey")

  @@index([user_id], map: "idx_user_exercises_user_id")
}

model users {
  id                    String                  @id
  first_name            String?
  last_name             String?
  email                 String                  @unique
  // Daily macro targets. Nullable = "not set"; the app falls back to its
  // local default (1800 cal) until the user saves targets. In coached mode
  // (see coach_profiles) the weekly plan generator owns these columns.
  target_calories       Int?
  target_protein_g      Int?
  target_carbs_g        Int?
  target_fat_g          Int?
  // Base64 JPEG, client-resized to ~192px (~10-20KB) — small enough to live
  // in the row instead of object storage.
  avatar_base64         String?
  // Profile fields for the Coach cold-start estimate (Mifflin-St Jeor) and
  // scheduling. All nullable: manual mode never requires them.
  sex                   String? // 'male' | 'female' | 'unspecified'
  birth_date            DateTime?               @db.Date
  height_cm             Float?
  weight_unit           String? // 'lbs' | 'kg' — synced from the client setting
  timezone              String? // IANA, e.g. 'America/Chicago'; refreshed on login
  // Coarse activity signal for inactivity win-back pushes. Updated by
  // middleware at most once per hour per user (see lastActive middleware).
  last_active_at        DateTime?
  templates             templates[]
  user_exercises        user_exercises[]
  personal_records      personal_records[]
  runs                  runs[]
  run_personal_records  run_personal_records[]
  body_weight_entries   body_weight_entries[]
  foods                 foods[]
  meals                 meals[]
  meal_entries          meal_entries[]
  coach_profiles        coach_profiles?
  expenditure_snapshots expenditure_snapshots[]
  coach_weekly_plans    coach_weekly_plans[]
}

model workout_days {
  id              String            @id(map: "workout_day_pkey") @db.Uuid
  user_id         String
  date            DateTime          @db.Date
  has_synced      Boolean?          @default(false)
  updated_at      BigInt            @default(0)
  daily_exercises daily_exercises[]

  @@unique([user_id, date], map: "unique_user_date")
}

model templates {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String
  name         String
  tagline      String
  exercise_ids String[]
  users        users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, name], map: "unique_user_template_name")
  @@index([user_id], map: "idx_templates_user_id")
}

// Current-best PR per user x exercise x record type. record_type is one of:
// MAX_WEIGHT | MAX_REPS | MAX_ESTIMATED_1RM | MAX_VOLUME | MAX_DURATION | MAX_DISTANCE
model personal_records {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String
  exercise_id     String         @db.Uuid
  record_type     String
  value           Float
  unit            String
  reps_at_record  Int?
  exercise_set_id String?        @db.Uuid
  achieved_at     DateTime
  created_at      DateTime       @default(now())
  users           users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user_exercises  user_exercises @relation(fields: [exercise_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, exercise_id, record_type], map: "unique_user_exercise_record_type")
  @@index([user_id], map: "idx_personal_records_user_id")
}

// Cardio session, sibling to workout_days rather than nested inside it.
// has_synced / updated_at mirror workout_days' offline-sync contract exactly.
model runs {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id              String
  started_at           DateTime
  ended_at             DateTime?
  duration_seconds     Int
  distance_meters      Float
  avg_pace_sec_per_km  Float?
  elevation_gain_m     Float?
  elevation_loss_m     Float?
  avg_heart_rate       Int?
  max_heart_rate       Int?
  calories             Int?
  run_type             String                 @default("OUTDOOR")
  source               String                 @default("MANUAL")
  route_polyline       String?                @db.Text
  notes                String?
  has_synced           Boolean?               @default(false)
  updated_at           BigInt                 @default(0)
  created_at           DateTime               @default(now())
  users                users                  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  run_splits           run_splits[]
  run_personal_records run_personal_records[]

  @@index([user_id, started_at], map: "idx_runs_user_id_started_at")
}

// One row per weigh-in. logged_at is a full timestamp (not a date) so the app
// can show time-of-day context ("morning") and allow multiple entries per day.
model body_weight_entries {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String
  weight     Float
  // 'lbs' | 'kg'. Null on legacy rows until backfilled from the user's current
  // weight_unit (decision: tdee-coach-plan.md §8.2); the Coach engine treats
  // null as the user's current unit and converts everything to kg internally.
  unit       String?
  logged_at  DateTime
  created_at DateTime @default(now())
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, logged_at], map: "idx_body_weight_entries_user_id_logged_at")
}

model run_splits {
  id               String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  run_id           String @db.Uuid
  split_number     Int
  distance_meters  Float
  duration_seconds Int
  pace_sec_per_km  Float?
  runs             runs   @relation(fields: [run_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([run_id, split_number], map: "unique_run_split_number")
}

// Separate from personal_records (rather than a nullable exercise_id there) because
// Postgres unique indexes treat NULL as distinct from NULL, so a nullable exercise_id
// would let duplicate run PR rows slip past the uniqueness guarantee. record_type here
// is one of: MAX_DISTANCE | MAX_DURATION | BEST_PACE
model run_personal_records {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String
  record_type String
  value       Float
  unit        String
  run_id      String?  @db.Uuid
  achieved_at DateTime
  created_at  DateTime @default(now())
  users       users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  runs        runs?    @relation(fields: [run_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([user_id, record_type], map: "unique_user_run_record_type")
}

// ---------------------------------------------------------------------------
// Macros (nutrition) — see ../macros-refactor-plan/ in the workspace root.
// ---------------------------------------------------------------------------

// Personal food library ("Your foods"). One row per user-owned food with
// per-serving values. Soft-deleted so meal_entries snapshots keep provenance.
model foods {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String
  name           String
  serving_amount Float          @default(1)
  serving_unit   String?
  calories       Int
  protein_g      Int
  carbs_g        Int
  fat_g          Int
  brand          String?
  source         String         @default("manual") // 'manual' | 'label_scan' | 'branded' | 'seed'
  created_at     DateTime       @default(now())
  updated_at     DateTime       @default(now()) @updatedAt
  deleted_at     DateTime?      @db.Timestamptz(6)
  users          users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  meal_entries   meal_entries[]

  @@index([user_id, name], map: "idx_foods_user_id_name")
}

// One row per meal per user-day (Breakfast/Lunch/Dinner defaults are created
// lazily on first read of a day; users can add/rename/delete custom meals).
model meals {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String
  date         DateTime       @db.Date
  name         String
  sort_order   Int            @default(0)
  created_at   DateTime       @default(now())
  deleted_at   DateTime?      @db.Timestamptz(6)
  users        users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  meal_entries meal_entries[]

  @@index([user_id, date], map: "idx_meals_user_id_date")
}

// One row per logged item inside a meal. Name/serving/macros are SNAPSHOTS
// taken at log time (per-serving values); displayed totals multiply by
// `servings` at read time. food_id is provenance only — renders never join
// through it, so library edits/deletes can't rewrite history.
model meal_entries {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  meal_id      String    @db.Uuid
  user_id      String // denormalized for cheap day/history aggregates
  date         DateTime  @db.Date // denormalized day key, matches meals.date
  food_id      String?   @db.Uuid
  name         String
  serving_text String?
  servings     Float     @default(1)
  calories     Int // per serving (as-eaten for AI items, servings = 1)
  protein_g    Int // per serving
  carbs_g      Int
  fat_g        Int
  input_method String    @default("library") // 'library' | 'search' | 'ai_text' | 'ai_photo'
  raw_input    String?   @db.Text
  logged_at    DateTime  @default(now())
  updated_at   DateTime  @default(now()) @updatedAt
  deleted_at   DateTime? @db.Timestamptz(6)
  meals        meals     @relation(fields: [meal_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  foods        foods?    @relation(fields: [food_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([user_id, date], map: "idx_meal_entries_user_id_date")
  @@index([meal_id], map: "idx_meal_entries_meal_id")
}

// Raw USDA responses keyed by normalized request (path + params). USDA data
// is public domain with no retention restrictions; stale rows are served
// immediately and refreshed in the background — see usda.service.
model usda_api_cache {
  cache_key  String   @id(map: "usda_api_cache_pkey")
  payload    Json
  fetched_at DateTime @default(now()) @db.Timestamptz(6)
}

// One row per user x UTC day, counting AI calls (estimate + label-scan share
// the pool). Enforces the free daily quota — see entitlement.service.
model ai_usage {
  user_id    String
  day        String // 'YYYY-MM-DD' (UTC)
  count      Int      @default(0)
  updated_at DateTime @default(now()) @updatedAt

  @@id([user_id, day], map: "ai_usage_pkey")
}

// ---------------------------------------------------------------------------
// Coach (adaptive TDEE) — see ../tdee-coach-plan.md in the workspace root.
// ---------------------------------------------------------------------------

// One row per user who has enrolled in coached mode. Absence of a row = manual
// mode. mode 'paused' freezes weekly plan generation but the engine keeps
// computing expenditure snapshots.
model coach_profiles {
  user_id      String   @id
  mode         String // 'coached' | 'paused'
  goal         String // 'lose' | 'maintain' | 'gain'
  rate_pct_bw  Float // %BW per week, always positive; direction comes from goal
  protein_pref Float? // g per kg override; null = engine default by goal
  fat_bias     String? // 'low' | 'balanced' | 'high'; null = 'balanced'
  started_at   DateTime @default(now())
  updated_at   DateTime @default(now()) @updatedAt
  users        users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

// One row per user x local day: the engine's daily output. Recomputed
// incrementally on read (GET /coach/state) and by the Phase-3 scheduler.
// Idempotent by construction — same inputs always produce the same rows.
model expenditure_snapshots {
  user_id         String
  day             DateTime @db.Date // user-local day
  trend_weight_kg Float? // null until the first weigh-in exists
  tdee_kcal       Int
  confidence      String // 'calibrating' | 'low' | 'medium' | 'high'
  users           users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, day], map: "expenditure_snapshots_pkey")
}

// One row per user x local week (Monday start): the coached targets for that
// week. The generator also writes users.target_* so the existing daily-macros
// response keeps working unchanged. rationale is machine-readable "why" data
// that powers the check-in copy (old/new TDEE, guardrails fired, data quality).
model coach_weekly_plans {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String
  week_start      DateTime  @db.Date // user-local Monday
  calories        Int
  protein_g       Int
  carbs_g         Int
  fat_g           Int
  tdee_kcal       Int // expenditure estimate at generation time
  rationale       Json
  acknowledged_at DateTime?
  created_at      DateTime  @default(now())
  users           users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, week_start], map: "unique_user_week_start")
  @@index([user_id], map: "idx_coach_weekly_plans_user_id")
}
